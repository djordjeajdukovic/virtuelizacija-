<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <add key="InputDirectory" value="..\..\Input" />
    <add key="ClientLogPath" value="Logs\client_rejects.txt" />
    <add key="MaxRowsToSend" value="100" />
    <add key="BatchSize" value="10" />
  </appSettings>
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="LargeStreamingTcpBinding" transferMode="Streamed" maxReceivedMessageSize="10485760" maxBufferSize="1048576" sendTimeout="00:10:00" receiveTimeout="00:10:00">
          <readerQuotas maxDepth="64" maxStringContentLength="10485760" maxArrayLength="10485760" />
        </binding>
      </netTcpBinding>
    </bindings>
    <client>
      <endpoint name="WindTurbineService" address="net.tcp://localhost:4002/WindTurbineService" binding="netTcpBinding" bindingConfiguration="LargeStreamingTcpBinding" contract="Common.IWindTurbineService" />
    </client>
  </system.serviceModel>
</configuration>
